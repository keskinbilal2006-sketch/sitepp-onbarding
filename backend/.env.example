NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://sitepp:sitepp@localhost:5432/sitepp?schema=public
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10
UPLOAD_DIR=./uploads
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.190:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
LOG_LEVEL=info
